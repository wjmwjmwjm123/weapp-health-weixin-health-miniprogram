<view class="tcm-page">
  <scroll-view class="tcm-scroll" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- Hero 区域 -->
    <view class="hero" bindtap="onHeroTap">
      <image class="hero-img" src="/static/tcm/hero-bg.jpg" mode="aspectFill" />
      <view class="hero-bg" />
      <view class="hero-content">
        <text class="hero-label">中医医生</text>
        <view class="hero-meta">
          <text class="hero-meta-item">积分 {{summary.points}}</text>
          <text class="hero-meta-dot">·</text>
          <text class="hero-meta-item">测评 {{summary.lastCheck}}</text>
        </view>
      </view>
    </view>

    <!-- 体质洞察 -->
    <view class="insight">
      <view class="insight-header">
        <text class="insight-title">今日体质</text>
        <text class="insight-badge">{{diagnosis.constitution}}</text>
      </view>
      <text class="insight-desc">{{diagnosis.advice}}</text>
      <view class="insight-tags">
        <text class="insight-tag" wx:for="{{focusTips}}" wx:key="index">{{item}}</text>
      </view>
    </view>

    <!-- 快速操作 -->
    <view class="quick-bar">
      <view class="quick-item" wx:for="{{quickActions}}" wx:key="id" data-id="{{item.id}}" data-url="{{item.url}}" bindtap="onActionTap">
        <view class="quick-icon">{{item.icon}}</view>
        <text class="quick-title">{{item.title}}</text>
      </view>
    </view>

    <!-- 当日药膳 -->
    <view class="recipe-section" wx:if="{{dailyRecipe}}" bindtap="onDailyRecipeTap">
      <image class="recipe-img" src="/static/tcm/recipe-bg.jpg" mode="aspectFill" />
      <view class="recipe-bg" />
      <view class="recipe-content">
        <view class="recipe-label">当日药膳 · {{dailyRecipe.timing}}</view>
        <text class="recipe-title">{{dailyRecipe.title}}</text>
        <text class="recipe-focus">{{dailyRecipe.focus}}</text>
        <view class="recipe-ingredients">
          <text wx:for="{{dailyRecipe.ingredients}}" wx:key="index" class="recipe-ing">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 理疗方案 -->
    <view class="section" wx:if="{{therapyPackages.length}}">
      <view class="section-header">
        <text class="section-title">理疗方案</text>
        <text class="section-more" bindtap="openClassroom">查看全部 ›</text>
      </view>
      <view class="therapy-list">
        <view class="therapy-item" wx:for="{{therapyPackages}}" wx:key="id">
          <view class="therapy-left">
            <text class="therapy-title">{{item.title}}</text>
            <text class="therapy-desc">{{item.desc}}</text>
            <view class="therapy-footer">
              <text class="therapy-tag">{{item.tag}}</text>
              <text class="therapy-duration">{{item.duration}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 生活常识 -->
    <view class="section" wx:if="{{lifeTips.length}}">
      <view class="section-header">
        <text class="section-title">生活常识</text>
      </view>
      <view class="life-list">
        <view class="life-row" wx:for="{{lifeTips}}" wx:key="id" data-index="{{index}}" bindtap="onLifeTipTap">
          <view class="life-dot" />
          <view class="life-body">
            <text class="life-title">{{item.title}}</text>
            <text class="life-summary">{{item.summary}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 中医知识快报 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">知识快报</text>
      </view>
      <view class="feed-list">
        <view class="feed-row" wx:for="{{knowledgeFeeds}}" wx:key="id" data-id="{{item.id}}" bindtap="onKnowledgeTap">
          <view class="feed-left">
            <text class="feed-tag">{{item.tag}}</text>
            <text class="feed-title">{{item.title}}</text>
          </view>
          <text class="feed-time">{{item.time}}</text>
        </view>
      </view>
    </view>

    <!-- 药膳教学入口 -->
    <view class="teaching-row" bindtap="onTeachingTap">
      <image class="teaching-img" src="/static/home/card1.png" mode="aspectFill" />
      <view class="teaching-mask" />
      <view class="teaching-content">
        <text class="teaching-title">药膳教学</text>
        <text class="teaching-desc">收录 {{medicatedLessons.length}} 个方子 · 季节调护 · 体质餐单</text>
      </view>
      <text class="teaching-arrow">›</text>
    </view>

    <view class="page-bottom" />
  </scroll-view>
</view>

