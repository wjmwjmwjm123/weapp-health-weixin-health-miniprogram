<view class="cart-container">
  <!-- 购物车为空时显示 -->
  <view wx:if="{{cartItems.length === 0}}" class="empty-cart">
    <t-icon name="shopping-cart" size="200rpx" color="#d9d9d9"></t-icon>
    <text class="empty-text">购物车空空如也</text>
    <button class="go-shopping-btn" bindtap="onGoToMall">去逛逛</button>
  </view>

  <!-- 购物车有商品时显示 -->
  <view wx:else class="cart-content">
    <!-- 顶部编辑按钮 -->
    <view class="cart-header">
      <text class="cart-title">购物车({{cartItems.length}})</text>
      <text class="edit-btn" bindtap="onToggleEdit">{{isEditing ? '完成' : '编辑'}}</text>
    </view>
    
    <!-- 商品列表 -->
    <view class="cart-items">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
        <view class="item-selector" bindtap="onSelectItem" data-id="{{item.id}}">
          <t-icon 
            wx:if="{{selectedItems.indexOf(item.id) > -1}}"
            name="check-circle-filled" 
            size="40rpx" 
            color="#1890ff"
          />
          <t-icon 
            wx:else
            name="check-circle" 
            size="40rpx" 
            color="#d9d9d9"
          />
        </view>
        <view class="item-content">
          <view class="item-image">
            <view class="item-image-placeholder">
              {{item.type === 'course' ? '🎥' : item.type === 'equipment' ? '🏋️' : '🌿'}}
            </view>
          </view>
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-desc">{{item.desc}}</text>
            <view class="item-price-section">
              <text class="item-price">¥{{item.price}}</text>
              <view class="quantity-control">
                <button class="quantity-btn" bindtap="onDecreaseQuantity" data-id="{{item.id}}">-</button>
                <text class="quantity">{{item.quantity}}</text>
                <button class="quantity-btn" bindtap="onIncreaseQuantity" data-id="{{item.id}}">+</button>
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{isEditing}}" class="item-actions">
          <button class="delete-btn" bindtap="onDeleteItem" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view class="cart-footer">
      <view class="footer-left">
        <view bindtap="onSelectAll">
          <t-icon 
            wx:if="{{selectedItems.length === cartItems.length && cartItems.length > 0}}"
            name="check-circle-filled" 
            size="40rpx" 
            color="#1890ff"
          />
          <t-icon 
            wx:else
            name="check-circle" 
            size="40rpx" 
            color="#d9d9d9"
          />
        </view>
        <text class="select-all-text">全选</text>
        <button wx:if="{{isEditing}}" class="clear-cart-btn" bindtap="onClearCart">清空</button>
      </view>
      <view class="footer-right">
        <text class="total-price">合计: ¥{{totalPrice}}</text>
        <button 
          class="checkout-btn {{selectedItems.length === 0 ? 'disabled' : ''}}" 
          bindtap="onCheckout"
          disabled="{{selectedItems.length === 0}}"
        >
          结算({{selectedItems.length}})
        </button>
      </view>
    </view>
  </view>
</view>