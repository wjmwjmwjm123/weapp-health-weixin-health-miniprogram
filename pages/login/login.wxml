<view class="login-container">
  <!-- 顶部大图 -->
  <view class="login-hero">
    <image class="login-hero-img" src="/static/home/swiper0.png" mode="aspectFill" />
    <view class="login-hero-mask" />
  </view>

  <!-- 内容区 -->
  <view class="login-body">
    <view class="login-header">
      <text class="login-greeting">欢迎来到</text>
      <text class="login-title">纤途无忧</text>
      <text class="login-subtitle">健康生活 · 中医调理 · 每日陪伴</text>
    </view>

    <!-- 功能亮点 -->
    <view class="login-features">
      <view class="feature-item">
        <text class="feature-icon">🌿</text>
        <text class="feature-text">中医体质</text>
      </view>
      <view class="feature-divider" />
      <view class="feature-item">
        <text class="feature-icon">🥣</text>
        <text class="feature-text">药膳调理</text>
      </view>
      <view class="feature-divider" />
      <view class="feature-item">
        <text class="feature-icon">🏃</text>
        <text class="feature-text">健康记录</text>
      </view>
    </view>

    <!-- 头像昵称填写 -->
    <view class="profile-setup">
      <button class="avatar-choose-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill" />
        <view class="avatar-edit-icon">
          <text>📷</text>
        </view>
      </button>
      <view class="nickname-wrap">
        <input
          type="nickname"
          class="nickname-input"
          placeholder="请输入昵称"
          value="{{nickname}}"
          bindblur="onNicknameBlur"
        />
      </view>
    </view>

    <!-- 登录按钮 -->
    <view class="login-actions">
      <view class="wechat-login-btn {{loading ? 'loading' : ''}} {{!isAgree ? 'disabled' : ''}}" bindtap="onWechatLogin">
        <image class="btn-icon" src="/static/icon_wx.png" mode="aspectFit" wx:if="{{!loading}}" />
        <view class="loading-spinner" wx:else></view>
        <text class="btn-text">{{loading ? '登录中...' : '微信一键登录'}}</text>
      </view>
    </view>

    <!-- 协议 -->
    <view class="login-agreement">
      <view class="agreement-check" bindtap="onToggleAgree">
        <view class="agree-box {{isAgree ? 'checked' : ''}}">
          <text class="agree-icon" wx:if="{{isAgree}}">✓</text>
        </view>
        <text class="agree-text">我已阅读并同意</text>
        <text class="link-text" bindtap="onShowAgreement">《用户协议》</text>
        <text class="link-divider">和</text>
        <text class="link-text" bindtap="onShowPrivacy">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 底部 -->
  <view class="login-footer">
    <text class="footer-text">登录即表示同意相关协议</text>
  </view>
</view>
