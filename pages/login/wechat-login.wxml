<view class="wechat-login-container">
  <view class="login-header">
    <view class="login-logo">🏃‍♀️</view>
    <view class="login-title">欢迎使用纤途无忧</view>
    <view class="login-subtitle">记录你的每一次努力</view>
  </view>

  <view class="login-content">
    <!-- 微信一键登录 -->
    <view class="login-button primary" bindtap="onWechatLogin">
      <view class="button-icon">🔐</view>
      <text class="button-text">{{loading ? '登录中...' : '微信一键登录'}}</text>
    </view>
  </view>

  <view class="login-footer">
    <text class="footer-text">登录即表示同意</text>
    <text class="footer-link">《用户协议》</text>
    <text class="footer-text">和</text>
    <text class="footer-link">《隐私政策》</text>
  </view>

  <!-- 加载提示 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">登录中...</text>
    </view>
  </view>
</view>
