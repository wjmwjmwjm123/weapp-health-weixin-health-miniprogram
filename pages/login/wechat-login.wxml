<view class="wechat-login-container">
  <view class="login-header">
    <view class="login-logo">🏃‍♀️</view>
    <view class="login-title">欢迎使用健身助手</view>
    <view class="login-subtitle">记录你的每一次努力</view>
  </view>

  <view class="login-content">
    <!-- 微信登录按钮（完整版） -->
    <view class="login-button primary" bindtap="onWechatLogin">
      <view class="button-icon">🔐</view>
      <text class="button-text">微信一键登录</text>
      <text class="button-desc">获取头像和昵称</text>
    </view>

    <!-- 简化登录按钮 -->
    <view class="login-button secondary" bindtap="onSimpleLogin">
      <view class="button-icon">⚡</view>
      <text class="button-text">快速登录</text>
      <text class="button-desc">无需授权，直接使用</text>
    </view>

    <!-- 手机号登录 -->
    <view class="login-button outline" bindtap="onPhoneLogin">
      <view class="button-icon">📱</view>
      <text class="button-text">手机号登录</text>
      <text class="button-desc">使用手机号验证码登录</text>
    </view>
  </view>

  <view class="login-footer">
    <text class="footer-text">登录即表示同意</text>
    <text class="footer-link">《用户协议》</text>
    <text class="footer-text">和</text>
    <text class="footer-link">《隐私政策》</text>
  </view>

  <!-- 加载提示 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">登录中...</text>
    </view>
  </view>
</view>

