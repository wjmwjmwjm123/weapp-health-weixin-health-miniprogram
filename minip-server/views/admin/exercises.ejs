<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - 纤途无忧</title>
  <link rel="stylesheet" href="/static/css/admin.css">
</head>
<body>
  <%- include('partials/sidebar') %>

  <div class="main-content">
    <div class="page-header">
      <h1>运动数据</h1>
    </div>

    <div class="toolbar">
      <input type="text" class="form-input search-input" id="searchInput" placeholder="搜索用户昵称...">
      <button class="btn btn-primary" onclick="loadExercises(1)">搜索</button>
    </div>

    <div class="data-table">
      <table>
        <thead>
          <tr>
            <th>用户</th>
            <th>日期</th>
            <th>步数</th>
            <th>时长(分钟)</th>
            <th>卡路里</th>
            <th>类型</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <tr><td colspan="6" class="loading">加载中...</td></tr>
        </tbody>
      </table>
    </div>

    <div class="pagination" id="pagination"></div>
  </div>

  <script>
    let currentPage = 1;
    let totalPages = 1;

    async function loadExercises(page = 1) {
      currentPage = page;
      const keyword = document.getElementById('searchInput').value.trim();
      const tbody = document.getElementById('tableBody');
      tbody.innerHTML = '<tr><td colspan="6" class="loading">加载中...</td></tr>';

      try {
        const res = await fetch(`/admin/api/exercises?page=${page}&pageSize=20&keyword=${encodeURIComponent(keyword)}`);
        const result = await res.json();
        if (result.code !== 200) return;

        const { total, list } = result.data;
        totalPages = Math.ceil(total / 20);

        if (list.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" class="empty">暂无数据</td></tr>';
        } else {
          tbody.innerHTML = list.map(r => `
            <tr>
              <td style="font-weight:600">${r.user ? r.user.nickname : '未知用户'}</td>
              <td style="color:var(--color-text-secondary)">${r.date}</td>
              <td style="font-weight:600">${(r.steps || 0).toLocaleString()}</td>
              <td>${r.duration || 0}</td>
              <td>${r.calories || 0}</td>
              <td><span class="badge" style="background:var(--color-primary-light);color:var(--color-primary-dark)">${r.type || '-'}</span></td>
            </tr>
          `).join('');
        }

        renderPagination();
      } catch (err) {
        tbody.innerHTML = '<tr><td colspan="6" class="error">加载失败</td></tr>';
      }
    }

    function renderPagination() {
      const container = document.getElementById('pagination');
      let html = '';
      html += `<button ${currentPage === 1 ? 'disabled' : ''} onclick="loadExercises(${currentPage - 1})">上一页</button>`;
      for (let i = 1; i <= totalPages; i++) {
        if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
          html += `<button class="${i === currentPage ? 'active' : ''}" onclick="loadExercises(${i})">${i}</button>`;
        } else if (i === currentPage - 2 || i === currentPage + 2) {
          html += `<span style="padding:6px 8px;color:var(--color-text-secondary)">...</span>`;
        }
      }
      html += `<button ${currentPage === totalPages ? 'disabled' : ''} onclick="loadExercises(${currentPage + 1})">下一页</button>`;
      container.innerHTML = html;
    }

    document.getElementById('searchInput').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') loadExercises(1);
    });

    loadExercises(1);
  </script>
</body>
</html>
